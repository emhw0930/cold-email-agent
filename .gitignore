# ── Secrets & credentials (NEVER commit) ──────────────────────
.env
assets/gmail_credentials.json
assets/gmail_token.json
assets/sheets_service_account.json
assets/*.json
# …but DO ship the retrieval-corpus template so forkers see the schema:
!assets/experience.example.json

# ── Personal documents ────────────────────────────────────────
assets/resume.pdf
assets/resume.txt
assets/cover_letter.pdf

# ── Python ────────────────────────────────────────────────────
venv/
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log

# data/h1b_employers.db IS committed on purpose (public USCIS-derived data):
# GitHub Actions runners are ephemeral and need the board cache and the
# emailed/seen dedup state that live inside it.

# Outreach retry state (PRIVATE: recruiter targets + email bodies) — never commit
data/outreach_state.db

# Résumé retrieval knowledge base (PRIVATE: résumé bullet text + embeddings) —
# rebuilt locally from assets/experience.json via `python src/resume_kb.py --build`
data/resume_kb.db

