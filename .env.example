# ============================================================
#  .env.example — copy to .env and fill in your own values
#    cp .env.example .env
#  .env is gitignored; this template is safe to commit.
# ============================================================

# Google Gemini key (https://aistudio.google.com → Get API key) — the only LLM,
# on the FREE tier. Writes cold emails AND scores daily fit-ranking. Recommended
# but optional: without it, ranking uses the free keyword scorer and outreach
# uses a plain template.
GEMINI_API_KEY=

# Prospeo (verified recruiter email lookup) — https://prospeo.io
# OPTIONAL: leave empty to skip; outreach then relies on pattern-guessed emails
PROSPEO_API_KEY=

# The Gmail address you send FROM
SENDER_EMAIL=your.email@gmail.com

# Optional: Gmail App Password (myaccount.google.com → Security → App passwords).
# When set, mail is sent via SMTP instead of the Gmail API — no OAuth browser
# flow, so it works headless (GitHub Actions). Requires 2-Step Verification.
GMAIL_APP_PASSWORD=

# Google Sheets spreadsheet ID (from the URL /spreadsheets/d/<ID>/edit)
# OPTIONAL: leave empty to skip the outreach log + its recipient dedup
SHEETS_SPREADSHEET_ID=

# Optional: Apps Script web-app URL to log daily-email card clicks to the "Job"
# sheet (col B) then redirect to the posting. Blank = links go straight to the job.
# Setup: docs/CLICK_TRACKER.md
CLICK_TRACKER_URL=

# Your profile (used in generated emails)
YOUR_NAME=Your Name
YOUR_PHONE=+1 (555) 000-0000
YOUR_LINKEDIN=https://linkedin.com/in/yourhandle
YOUR_EMAIL_PRIMARY=your.email@gmail.com
YOUR_EMAIL_ALT=                              # optional second email shown in the signature
YOUR_BIO=a new-grad software engineer seeking entry-level SWE roles

# ── Optional (sensible defaults in src/config.py) ─────────────
# GEMINI_MODEL=gemini-2.5-flash-lite         # Gemini model for ranking + emails
# VERIFIED_ONLY=true                         # only send to Prospeo-verified emails
# DRY_RUN=false                              # true = never actually send
# EMAIL_SEND_DELAY_SECONDS=5                 # pause between sends
# YOUR_GITHUB=https://github.com/yourhandle  # not used in the signature by default
