# ── Secrets & credentials (NEVER commit) ──────────────────────
.env
.env.*
!.env.example
# ALL JSON under assets/ (service account keys, OAuth tokens, experience corpus)…
assets/*.json
# …but DO ship the retrieval-corpus template so forkers see the schema:
!assets/experience.example.json

# ── Personal documents (résumé, cover letter, ANY backups) ────
# Ignore every PDF/text/LaTeX résumé source in assets — including dated backups
# like resume_backup_YYYYMMDD.pdf — so personal docs are never public.
assets/*.pdf
assets/*.txt
assets/*.docx

# ── Python ────────────────────────────────────────────────────
venv/
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log

# ── Databases (PRIVATE by default) ────────────────────────────
# Ignore ALL local DBs so personal data can never leak — outreach_state,
# resume_kb, agent_log, applications, and any future .db added later.
data/*.db
# …EXCEPT the public USCIS-derived employer DB, committed on purpose so the
# GitHub Action has the board cache + emailed/seen dedup state (ephemeral runners).
!data/h1b_employers.db

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
.idea/
.vscode/

# Claude Code local settings
.claude/

# Resume source files (personal info)
*.tex
resume_updated.tex
